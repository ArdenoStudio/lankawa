{
  "name": "@cookie-cat21/gdacs-firms-docs-client",
  "version": "0.1.0",
  "description": "Unofficial TypeScript client for GDACS + NASA FIRMS. Not affiliated with upstream.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke": "node --import tsx examples/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "sri-lanka",
    "unofficial-api",
    "gdacs-firms-docs",
    "typescript"
  ],
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
